{
  "name": "ia-microservice",
  "version": "1.0.0",
  "description": "Simple Node.js microservice that proxies GET requests to OpenRouter.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "lucide-react": "^1.14.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "stripe": "^22.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
